# Upstash Redis (auto-provisioned via Vercel Marketplace: vercel integration add upstash/upstash-kv)
# Vercel Marketplace uses KV_* prefix; manual Upstash setups use UPSTASH_REDIS_REST_* prefix.
# The app supports both — whichever is present will be used.

# Vercel Marketplace (auto-filled by: vercel env pull)
KV_REST_API_URL=https://your-redis-url.upstash.io
KV_REST_API_TOKEN=your-token-here

# Manual Upstash setup (alternative)
# UPSTASH_REDIS_REST_URL=https://your-redis-url.upstash.io
# UPSTASH_REDIS_REST_TOKEN=your-token-here

# Public app URL (used for QR code generation — optional, falls back to window.location.origin)
NEXT_PUBLIC_APP_URL=http://localhost:3000
